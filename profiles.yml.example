# Copy this file to ~/.dbt/profiles.yml and fill in your credentials.
# The profile name must match the `profile` field in dbt_project.yml ("pmf").
#
# Pick the block for your warehouse and delete the rest.

pmf:
  target: dev
  outputs:

    # ── PostgreSQL / Redshift ───────────────────────────────────────────────
    dev:
      type: postgres
      host: localhost
      user: your_user
      password: your_password
      port: 5432
      dbname: your_database
      schema: pmf_output       # dbt writes output tables here

    # ── BigQuery ────────────────────────────────────────────────────────────
    # dev:
    #   type: bigquery
    #   method: oauth
    #   project: your-gcp-project
    #   dataset: pmf_output
    #   threads: 4

    # ── Snowflake ───────────────────────────────────────────────────────────
    # dev:
    #   type: snowflake
    #   account: your_account
    #   user: your_user
    #   password: your_password
    #   role: your_role
    #   database: your_database
    #   warehouse: your_warehouse
    #   schema: pmf_output

    # ── DuckDB ──────────────────────────────────────────────────────────────
    # dev:
    #   type: duckdb
    #   path: pmf.duckdb        # local file; use ':memory:' for in-memory
    #   schema: pmf_output
